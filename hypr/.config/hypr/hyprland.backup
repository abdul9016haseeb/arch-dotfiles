# #######################################################################################
# AUTOGENERATED HYPRLAND CONFIG.
# EDIT THIS CONFIG ACCORDING TO THE WIKI INSTRUCTIONS.
# #######################################################################################



# This is an example Hyprland config file.
# Refer to the wiki for more information.
# https://wiki.hypr.land/Configuring/

# Please note not all available settings / options are set here.
# For a full list, see the wiki

# You can split this configuration into multiple files
# Create your files separately and then link them to this file like this:
# source = ~/.config/hypr/myColors.conf


################
### MONITORS ###
################

# See https://wiki.hypr.land/Configuring/Monitors/
monitor=,preferred,auto,auto


#############################
### ENVIRONMENT VARIABLES ###
#############################

# See https://wiki.hypr.land/Configuring/Environment-variables/

# change monitor to high resolution, the last argument is the scale factor
monitor=,highres,auto,1.5

# unscale XWayland
xwayland {
  force_zero_scaling = true
}

#GDK SCALE AND DPI
env = GDK_SCALE,1.5
env = GDK_DPI_SCALE,1


env = QT_QPA_PLATFORMTHEME,qt6ct
env = QT_QPA_PLATFORM,wayland;xcb
env = QT_WAYLAND_DISABLE_WINDOWDECORATION,1

# Hardware (AMD Ryzen Graphics)
#env = LIBVA_DRIVER_NAME,radeonsi
#env = VDPAU_DRIVER,radeonsi

env = MOZ_ENABLE_WAYLAND,1
env = ELECTRON_OZONE_PLATFORM_HINT,wayland

env = GDK_BACKEND,wayland,x11
env = GTK_THEME,Adwaita:dark

env = XCURSOR_SIZE,24
env = HYPRCURSOR_SIZE,24

###################
### MY PROGRAMS ###
###################

# See https://wiki.hypr.land/Configuring/Keywords/

# Set programs that you use
$terminal = kitty
$fileManager = dolphin
#$menu = hyprlauncher
$menu = wofi --show drun 

#################
### AUTOSTART ###
#################

# Autostart necessary processes (like notifications daemons, status bars, etc.)
# Or execute your favorite apps at launch like this:

# exec-once = $terminal
exec-once = nm-applet &
exec-once = waybar
exec-once=/usr/lib/polkit-kde-authentication-agent-1

exec-once = awww-daemon --no-cache
#exec-once = sleep 1 && awww img /home/abdul/Pictures/linux-customization-wallpaper-settings/anime-boy-winter-magick-1920x1200.jpeg --transition-type none

# exec-once = sleep 2 && /usr/lib/xdg-desktop-portal-hyprland &
# exec-once = sleep 3 && /usr/lib/xdg-desktop-portal-gtk &
# exec-once = sleep 2 && /usr/lib/xdg-desktop-portal &



exec-once = sleep 1 && awww img /home/abdul/Pictures/linux-customization-wallpaper-settings/minato-namikaze-magick-1920x1200.png --transition-type none
#exec-once = sleep 1 && awww img /home/abdul/Pictures/linux-customization-wallpaper-settings/genship_wallpaper/Green-eye-1920x1200.jpeg  --transition-type none
#exec-once = sleep 1 && awww img /home/abdul/Pictures/linux-customization-wallpaper-settings/anime-boy-winter-magick-1920x1200.jpeg  --transition-type none
#exec-once = sleep 1 && awww img /home/abdul/Pictures/painting-mountain-lake-with-mountain-background.jpg
#exec-once = sleep 1 && awww img /home/abdul/Pictures/misurina-sunset.jpg --transition-type grow --transition-pos 0.5,0.5
#exec-once = sleep 1 && awww img /home/abdul/Pictures/joshua-woroniecki-3mXIZP6_6zY-unsplash.jpg --transition-type grow --transition-pos 0.5,0.5
#exec-once = sleep 1 && awww img ~/Pictures/painting-mountain-lake-with-mountain-background.jpg 
#for random wallpaper
